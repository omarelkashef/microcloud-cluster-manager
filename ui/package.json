{
  "name": "lxd-cluster-manager-ui",
  "version": "0.0.1",
  "author": "Canonical Webteam",
  "license": "LGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "clean": "rm -rf node_modules yarn-error.log *.log build/ .jekyll-metadata .bundle playwright-report test-results build",
    "build": "VITE_BASE_URL=/ui/ npx vite build --emptyOutDir",
    "format-js-eslint": "eslint 'src/**/*.{json,jsx,tsx,ts}' 'tests/**/*.ts' --fix",
    "format-js-prettier": "prettier 'src/**/*.{json,jsx,tsx,ts}' 'tests/**/*.ts' --write",
    "format-js": "yarn format-js-eslint && yarn format-js-prettier",
    "lint-scss": "stylelint 'src/**/*.scss'",
    "lint-js-eslint": "eslint 'src/**/*.{json,tsx,ts}' 'tests/**/*.ts' .eslintrc.cjs",
    "lint-js-prettier": "prettier 'src/**/*.{json,tsx,ts}' 'tests/**/*.ts' .eslintrc.cjs --check",
    "lint-js": "yarn lint-js-eslint && yarn lint-js-prettier",
    "hooks-add": "husky install",
    "hooks-remove": "husky uninstall",
    "start": "./entrypoint 0.0.0.0:${PORT}",
    "backend-run": "cd .. && make && go run ./cmd/lxd-cluster-mgrd --state-dir ./state/dir1/",
    "backend-init": "cd .. &&  go run ./cmd/lxd-cluster-mgr --state-dir ./state/dir1/ waitready && go run ./cmd/lxd-cluster-mgr --state-dir ./state/dir1/ init \"member1\" 0.0.0.0:9001 --bootstrap --control-address 0.0.0.0:9010 && scripts/generate_clusters.sh --local && scripts/generate_configs.sh --local && scripts/generate_cluster_join_token.sh --local",
    "test-e2e": "cd .. && scripts/generate_configs.sh --local && cd ui && npx playwright test",
    "test-e2e-update": "npx playwright test --update-snapshots"
  },
  "dependencies": {
    "@canonical/react-components": "1.2.3",
    "@tanstack/react-query": "5.40.0",
    "@use-it/event-listener": "0.1.7",
    "formik": "2.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.23.1",
    "react-useportal": "1.0.19",
    "vanilla-framework": "4.15.0",
    "yup": "1.4.0"
  },
  "devDependencies": {
    "@babel/core": "7.24.6",
    "@babel/eslint-parser": "7.24.6",
    "@babel/preset-env": "7.24.6",
    "@babel/preset-react": "7.24.6",
    "@babel/preset-typescript": "7.24.6",
    "@playwright/test": "1.44.1",
    "@types/dotenv": "^8.2.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@types/react-router-dom": "5.3.3",
    "@types/websocket": "1.0.10",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "@vitejs/plugin-react": "4.3.0",
    "autoprefixer": "10.4.19",
    "babel-plugin-istanbul": "6.1.1",
    "concurrently": "8.2.2",
    "dotenv": "^16.4.5",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "7.33.2",
    "husky": "9.0.11",
    "lint-staged": "15.2.5",
    "postcss": "8.4.38",
    "postcss-cli": "11.0.0",
    "prettier": "3.2.5",
    "sass": "1.77.2",
    "stylelint": "16.6.0",
    "stylelint-config-standard-scss": "13.1.0",
    "stylelint-order": "6.0.4",
    "stylelint-prettier": "5.0.0",
    "stylelint-scss": "6.3.0",
    "typescript": "5.4.5",
    "vite": "5.2.11",
    "vite-plugin-istanbul": "6.0.2",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "1.6.0"
  },
  "lint-staged": {
    "src/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "tests/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "src/**/*.scss": "stylelint"
  }
}
