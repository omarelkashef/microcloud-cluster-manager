{
  "name": "microcloud-cluster-manager-ui",
  "version": "0.0.1",
  "author": "Canonical Webteam",
  "license": "LGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "clean": "rm -rf node_modules yarn-error.log *.log build/ .jekyll-metadata .bundle playwright-report test-results build",
    "build": "VITE_BASE_URL=/ui/ npx vite build --emptyOutDir",
    "format-js-eslint": "eslint 'src/**/*.{json,jsx,tsx,ts}' 'tests/**/*.ts' --fix",
    "format-js-prettier": "prettier 'src/**/*.{json,jsx,tsx,ts}' 'tests/**/*.ts' --write",
    "format-js": "yarn format-js-eslint && yarn format-js-prettier",
    "lint-scss": "stylelint 'src/**/*.scss'",
    "lint-js-eslint": "eslint 'src/**/*.{json,tsx,ts}' 'tests/**/*.ts'",
    "lint-js-prettier": "prettier 'src/**/*.{json,tsx,ts}' 'tests/**/*.ts' --check",
    "lint-js": "tsc --noEmit && yarn lint-js-eslint && yarn lint-js-prettier",
    "hooks-add": "husky install",
    "hooks-remove": "husky uninstall",
    "start": "./entrypoint ma.lxd-cm.local:${PORT}",
    "test-combine-coverage-reports": "cp coverage/unit/coverage-final.json coverage/playwright/ ; nyc report --reporter html --reporter cobertura --reporter text-summary --temp-dir coverage/playwright --report-dir coverage/playwright-report --exclude 'src/lib/**' --exclude 'src/types/**'",
    "test-e2e-coverage": "npx playwright test --project chromium",
    "test-e2e-update": "npx playwright test --update-snapshots",
    "test-unit": "vitest --run",
    "test-unit-coverage": "vitest --run --coverage"
  },
  "dependencies": {
    "@canonical/react-components": "3.8.3",
    "@tanstack/react-query": "5.90.16",
    "@use-it/event-listener": "0.1.7",
    "formik": "2.4.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-router-dom": "7.12.0",
    "vanilla-framework": "4.39.0",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/eslint-parser": "7.28.5",
    "@babel/preset-env": "7.28.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@canonical/typescript-config-react": "0.11.0",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.57.0",
    "@types/convert-source-map": "2.0.3",
    "@types/dotenv": "8.2.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/websocket": "1.0.10",
    "@typescript-eslint/eslint-plugin": "8.51.0",
    "@typescript-eslint/parser": "8.51.0",
    "@vitest/coverage-istanbul": "4.0.16",
    "@vitejs/plugin-react": "5.1.2",
    "autoprefixer": "10.4.23",
    "babel-plugin-istanbul": "7.0.1",
    "concurrently": "9.2.1",
    "convert-source-map": "2.0.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.4",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.0.0",
    "husky": "9.1.7",
    "nyc": "17.1.0",
    "lint-staged": "16.2.7",
    "postcss": "8.5.6",
    "postcss-cli": "11.0.1",
    "prettier": "3.7.4",
    "sass": "1.97.1",
    "stylelint": "16.26.1",
    "stylelint-config-standard-scss": "16.0.0",
    "stylelint-order": "7.0.1",
    "stylelint-prettier": "5.0.3",
    "stylelint-scss": "6.14.0",
    "typescript": "5.9.3",
    "v8-to-istanbul": "9.3.0",
    "vite": "7.3.0",
    "vite-plugin-istanbul": "7.2.1",
    "vite-tsconfig-paths": "6.0.3",
    "vitest": "4.0.16"
  },
  "lint-staged": {
    "src/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "tests/**/*.{json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ],
    "src/**/*.scss": "stylelint"
  }
}
